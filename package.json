{
  "type": "module",
  "name": "seo-tools",
  "version": "1.0.0",
  "packageManager": "pnpm@11.0.0",
  "scripts": {
    "dev": "docker compose -f docker-compose.dev.yml up --build",
    "build": "node scripts/run-local-bin.mjs next build --webpack",
    "start": "node scripts/run-local-bin.mjs next start",
    "lint": "node scripts/run-local-bin.mjs eslint",
    "check": "node scripts/run-local-bin.mjs tsc --noEmit",
    "type-check": "node scripts/run-local-bin.mjs tsc --noEmit",
    "test": "node scripts/run-local-bin.mjs vitest run",
    "test:watch": "node scripts/run-local-bin.mjs vitest",
    "test:e2e": "node scripts/run-local-bin.mjs playwright test",
    "test:e2e:ui": "node scripts/run-local-bin.mjs playwright test --ui",
    "seo": "node scripts/seo.mjs",
    "collect-daily": "node scripts/collect-daily.mjs",
    "sitemap-sync": "node scripts/sitemap-resubmit.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@google-analytics/admin": "^9.0.1",
    "@google-analytics/data": "^5.2.1",
    "@googleapis/searchconsole": "^6.0.1",
    "@tailwindcss/postcss": "^4.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "better-sqlite3": "^12.11.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.1",
    "google-auth-library": "^10.6.2",
    "next": "^16.2.1",
    "postcss": "^8.5.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7"
  }
}
